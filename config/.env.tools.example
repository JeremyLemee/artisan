# Tool API Keys - Copy this file to .env.tools and fill in your keys
# These secrets are accessible to generated tools via get_secret()
# The agent only sees the key names, never the actual values

OPENWEATHER_TOOL_API_KEY=your_openweather_key_here
GITHUB_TOOL_API_KEY=your_github_token_here
SLACK_TOOL_API_KEY=your_slack_token_here
